{
  "name": "pocket-ai",
  "version": "1.0.0",
  "description": "**어디서든 PC의 AI CLI 세션을 이어서 사용하세요**",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "./dev.sh",
    "setup": "npm install && npm run build:wire && npm run migrate",
    "build:wire": "npm run build --workspace=packages/wire",
    "migrate": "npm run migrate:up --workspace=apps/server",
    "test": "echo \"Error: no test specified\" && exit 1",
    "postinstall": "npm run build:wire && chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
