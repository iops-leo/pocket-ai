# ── Database (Supabase) ───────────────────────────────────
# Supabase > Project Settings > Database > Connection String > URI
# Session mode (port 5432) - 로컬 개발용
# Transaction mode (port 6543) - Railway 프로덕션용 (연결 풀링)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# 실제 프로젝트: aws-1-ap-south-1.pooler.supabase.com (Project: dsjuxgxshwsghbxytded)

# ── JWT ──────────────────────────────────────────────────
# openssl rand -base64 32 로 생성
JWT_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────
# https://github.com/settings/applications
# Homepage URL: https://pocket-ai-pwa.vercel.app
# Callback URL: https://pocket-ai-production.up.railway.app/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://pocket-ai-production.up.railway.app/auth/github/callback

# 로컬 개발 시:
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── CORS ─────────────────────────────────────────────────
# PWA Vercel 배포 URL (쉼표로 여러 개 가능)
ALLOWED_ORIGINS=https://pocket-ai-pwa.vercel.app

# 로컬 개발 시:
# ALLOWED_ORIGINS=http://localhost:3002

# ── PWA URL (OAuth 리다이렉트 후 이동 목적지) ────────────
PWA_URL=https://pocket-ai-pwa.vercel.app

# 로컬 개발 시:
# PWA_URL=http://localhost:3002

# ── 서버 포트 (Railway는 자동 주입, 로컬 기본값) ─────────
PORT=3001
