# ── Auth Mode ────────────────────────────────────────────
# single: 토큰 기반 싱글유저 인증 (기본값, 셀프호스팅용)
# github: GitHub OAuth 인증
AUTH_MODE=single

# ── Single-user Token (AUTH_MODE=single) ─────────────────
# 미설정 시 서버 시작할 때마다 자동 생성 → 콘솔에 출력
# AUTH_TOKEN=my-secret-token

# ── Database ─────────────────────────────────────────────
# SQLite 파일 경로 (기본값: ./data/pocket-ai.db)
# DATABASE_PATH=./data/pocket-ai.db

# ── JWT ──────────────────────────────────────────────────
# openssl rand -base64 32 로 생성
JWT_SECRET=

# ── GitHub OAuth (AUTH_MODE=github 일 때만 필요) ─────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:9741/auth/github/callback

# ── CORS ─────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:9742

# ── PWA URL (OAuth 리다이렉트) ───────────────────────────
# PWA_URL=http://localhost:9742

# ── 서버 포트 ────────────────────────────────────────────
PORT=9741
