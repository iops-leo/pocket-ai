# ── Database (Supabase) ───────────────────────────────────
# Supabase > Project Settings > Database > Connection String > URI
# Transaction mode (port 6543) 사용 - Railway와 연결 시 권장
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ── JWT ──────────────────────────────────────────────────
# openssl rand -base64 32 로 생성
JWT_SECRET=

# ── GitHub OAuth ─────────────────────────────────────────
# https://github.com/settings/applications/new
# Homepage URL: https://your-railway-app.railway.app
# Callback URL: https://your-railway-app.railway.app/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-railway-app.railway.app/auth/github/callback

# ── CORS ─────────────────────────────────────────────────
# PWA Vercel 배포 URL (쉼표로 여러 개 가능)
ALLOWED_ORIGINS=https://your-pwa.vercel.app

# ── PWA URL (OAuth 리다이렉트 후 이동 목적지) ────────────
PWA_URL=https://your-pwa.vercel.app

# ── 서버 포트 (Railway는 자동 주입, 로컬 기본값) ─────────
PORT=3001
